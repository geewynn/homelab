set timeout=30
set default=0

terminal_input console
terminal_output console

menuentry 'Ubuntu 24.04 Autoinstall' {
    linux /casper/vmlinuz ip=dhcp url=http://{{ ansible_facts['default_ipv4']['address'] }}/iso/{{ iso_url | basename }} autoinstall cloud-config-url=http://{{ ansible_facts['default_ipv4']['address'] }}/init-config/${net_default_mac}/user-data
    initrd /casper/initrd
}